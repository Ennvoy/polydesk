{
  "name": "polydesk",
  "version": "0.12.0",
  "description": "Polydesk — 多工作區開發終端機（Electron skeleton）",
  "author": "Polydesk",
  "license": "MIT",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "dist": "electron-vite build && electron-builder --win",
    "pack:dir": "electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/space-mono": "^5.2.9",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "dockview-core": "^7.0.2",
    "dockview-react": "^7.0.2",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "mammoth": "^1.12.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.12.0",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.18.1",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@electron/rebuild": "^4.0.6",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.polydesk.app",
    "productName": "Polydesk",
    "directories": {
      "output": "../polydesk-dist"
    },
    "npmRebuild": false,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/node-pty/**",
      "**/node_modules/@vscode/ripgrep/**"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "Polydesk-${version}-portable.exe"
    }
  }
}
